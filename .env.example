# ─── 100% FREE CLOUD STACK ──────────────────────────────────────────────────
# Instructions:
# 1. Host on Hugging Face Spaces (Free)
# 2. Get a free key from console.groq.com
# 3. Get a free instance from neo4j.com/cloud/aura/
# 4. Use local embeddings (included in Docker image)

LLM_PROVIDER=groq                # groq for free/fast LLM
GROQ_API_KEY=gsk_...             # Get from console.groq.com
EXTRACTION_MODEL=llama3-70b-8192 # Powerful enough for GraphRAG
SUMMARIZATION_MODEL=llama3-8b-8192

EMBEDDING_PROVIDER=local         # Use local CPU/GPU for embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2 # Small, fast, and free
EMBEDDING_DIM=384

GRAPH_BACKEND=neo4j
NEO4J_URI=neo4j+s://...          # AuraDB Free URI
NEO4J_USER=neo4j
NEO4J_PASSWORD=...               # AuraDB Password

# ─── ALTERNATIVE: 100% LOCAL (OLLAMA) ────────────────────────────────────────
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# EXTRACTION_MODEL=llama3
# EMBEDDING_PROVIDER=local
# GRAPH_BACKEND=networkx

