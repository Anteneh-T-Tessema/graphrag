# ─── LLM Provider ───────────────────────────────────────────────────────────
LLM_PROVIDER=ollama               # openai | ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=sk-...             # Required if LLM_PROVIDER=openai

# ─── Model Configuration ─────────────────────────────────────────────────────
# For Ollama, use models like: llama3, mistral, or phi3
EXTRACTION_MODEL=llama3          # Used for entity & relationship extraction
SUMMARIZATION_MODEL=llama3       # Used for community summarization
EMBEDDING_MODEL=mxbai-embed-large # Used for retrieval embeddings
EMBEDDING_DIM=1024

# ─── Pipeline Configuration ──────────────────────────────────────────────────
CHUNK_SIZE=1200                  # tokens per chunk
CHUNK_OVERLAP=100                # overlap between chunks
MAX_ENTITIES_PER_CHUNK=30        # cap to avoid token overruns

# ─── Community Detection ─────────────────────────────────────────────────────
COMMUNITY_ALGORITHM=louvain      # leiden | louvain | label_propagation
RESOLUTION=1.0                   # higher = more, smaller communities

# ─── Storage ─────────────────────────────────────────────────────────────────
GRAPH_OUTPUT_DIR=./output/graph
CHROMA_PERSIST_DIR=./output/chroma
SUMMARIES_OUTPUT_DIR=./output/summaries
