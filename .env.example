# ─── LLM Configuration ────────────────────────────────────────────────────────
# Options: openai | ollama | groq
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1

# API Keys (only needed for openai or groq)
OPENAI_API_KEY=
GROQ_API_KEY=

# Model Selection
# For local (Ollama): llama3, phi3, mistral
# For OpenAI: gpt-4o, gpt-4o-mini
EXTRACTION_MODEL=llama3
SUMMARIZATION_MODEL=llama3

# ─── Embeddings ─────────────────────────────────────────────────────────────
# Options: openai | local
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ─── Chunking ─────────────────────────────────────────────────────────────
CHUNK_SIZE=1200
CHUNK_OVERLAP=100
MAX_ENTITIES_PER_CHUNK=20

# ─── Community Detection ───────────────────────────────────────────────────
COMMUNITY_ALGORITHM=louvain
RESOLUTION=1.0

# ─── Storage ───────────────────────────────────────────────────────────────
GRAPH_BACKEND=networkx
GRAPH_OUTPUT_DIR=./output/graph
CHROMA_PERSIST_DIR=./output/chroma
SUMMARIES_OUTPUT_DIR=./output/summaries

# ─── Neo4j (optional) ──────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
